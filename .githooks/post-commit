#!/bin/bash
# Auto-sync to GitHub after every Replit commit.
# Uses the Replit GitHub integration via the Git Data API — no personal token needed.
# Runs synchronously so any failure is immediately visible in the commit output.

WORKSPACE_ROOT="$(git rev-parse --show-toplevel)"

cd "$WORKSPACE_ROOT"
pnpm --filter @workspace/scripts run github-sync 2>&1 | tee -a /tmp/github-sync.log

exit 0
